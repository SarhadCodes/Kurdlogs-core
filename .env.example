# KurdLogs Core — copy to .env on the VPS
PUBLIC_BASE_URL=http://YOUR_VPS_IP:8081

# Comma-separated browser origins (VPS + optional local dev)
CORS_ORIGIN=http://YOUR_VPS_IP:8081,http://localhost:8081,http://localhost

JWT_SECRET=change-me-long-random-secret
IPTV_API_KEY=change-me-iptv-api-key
POSTGRES_PASSWORD=change-me-db-password

# Web port on the host (8081 avoids conflict with Flussonic/nginx on port 80)
HTTP_PORT=8081

# KurdLogs MCR RTMP (1936 avoids Flussonic on 1935)
RTMP_PUBLISH_PORT=1936
MCR_RTMP_PORT=1936

TOKEN_OVERLAP_SECONDS=120
TOKEN_REFRESH_AHEAD_SECONDS=90

# Video encoding: cpu (recommended on VPS) | auto | nvenc | qsv | vaapi
# Use cpu unless you have a real GPU passed into Docker (see docker-compose.gpu.yml)
FFMPEG_ENCODER_MODE=cpu
NVENC_PRESET=p4
